# Tampa APP — example environment variables.
# Copy this file to .env.local and fill in your own values.
# Vite only exposes vars prefixed with VITE_ to the browser.

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Printing is browser-direct via Web Bluetooth or WebUSB — no print-server
# or printer-host environment variables are required.
